{
  "name": "the-friends-hub",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client",
    "server": "npm run start --workspace=server",
    "dev:full": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run dev\"",
    "build": "npm run build --workspace=client",
    "preview": "npm run preview --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  }
}
